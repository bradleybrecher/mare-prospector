# ==============================================================================
# MaRe Head Spa — Environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ==============================================================================

# --- Google Gemini -----------------------------------------------------------
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Default model. MaRe is committed to 2.5 Pro for everything client-facing.
# Requires billing enabled on the Google Cloud project tied to this API key.
# To dial back cost on bulk work, set GEMINI_MODEL=gemini-2.5-flash and Pro
# will still be used for reasoning-flagged calls via GEMINI_REASONING_MODEL.
GEMINI_MODEL=gemini-2.5-pro

# Reasoning model (currently identical to default; kept separate so you can
# drop GEMINI_MODEL to flash later without losing Pro on the reasoning paths).
GEMINI_REASONING_MODEL=gemini-2.5-pro

# Graceful-degradation model. If the primary model 429s (quota exhausted or
# billing not yet enabled), we automatically fall back to this one so the
# pipeline keeps moving. Set to "none" to disable fallback and surface the 429.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Generation defaults (override per-call in code when needed)
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_OUTPUT_TOKENS=2048

# --- Vertex AI (optional, recommended for production rendering) -------------
# Route Imagen 4 and Gemini text generation through Google Cloud Vertex AI
# instead of the AI Studio key. Bypasses AI Studio free-tier caps and uses
# your GCP billing.
#
# One-time setup — pick ONE auth path:
#
# Path A: Service Account JSON (no gcloud CLI install needed)
#   1. Enable Vertex AI API on your GCP project:
#        https://console.cloud.google.com/apis/library/aiplatform.googleapis.com
#   2. Create a service account with the "Vertex AI User" role:
#        https://console.cloud.google.com/iam-admin/serviceaccounts
#   3. Download a JSON key for it. Save it to `backend/secrets/vertex-sa.json`
#      (that folder is gitignored).
#   4. Fill VERTEX_PROJECT + GOOGLE_APPLICATION_CREDENTIALS below.
#
# Path B: gcloud Application Default Credentials
#   1. brew install --cask google-cloud-sdk  (or equivalent installer)
#   2. gcloud auth application-default login
#   3. gcloud services enable aiplatform.googleapis.com --project <id>
#   4. Fill VERTEX_PROJECT below.
#
# Probe with `python backend/scripts/probe_vertex.py` before flipping
# USE_VERTEX_* to true.

VERTEX_PROJECT=
VERTEX_LOCATION=us-central1

# Path A only: absolute OR repo-relative path to your service account JSON.
# Leave blank if you're using `gcloud auth application-default login` (Path B).
GOOGLE_APPLICATION_CREDENTIALS=

# Flip on to route text generation (shorts, blogs, outreach, postcards, social)
# through Vertex. Unblocks AI Studio's free-tier cap of 20 Flash req/day and
# lets text share billing with Imagen. Recommended: on.
USE_VERTEX_FOR_TEXT=false

# Flip on to route image rendering through Vertex. Requires VERTEX_PROJECT set.
USE_VERTEX_FOR_IMAGES=false

# --- Brand / Runtime ---------------------------------------------------------
# Where generated artifacts (drafts, scripts, outreach messages) are written.
ARTIFACT_DIR=./artifacts

# Log level for the Python backend: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Frontend (Next.js) ------------------------------------------------------
# Base URL the dashboard calls for backend APIs (when wired up later).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
